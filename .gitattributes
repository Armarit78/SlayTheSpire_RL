###############################################################################
# Global settings
###############################################################################

# Auto detect text files and normalize to LF in repo
* text=auto

###############################################################################
# Python / code files -> LF
###############################################################################

*.py text eol=lf
*.pyi text eol=lf
*.pyw text eol=lf

*.sh text eol=lf
*.bash text eol=lf

*.yml text eol=lf
*.yaml text eol=lf

*.md text eol=lf
*.txt text eol=lf

###############################################################################
# Data files
###############################################################################

*.json text eol=lf
*.csv text eol=lf
*.tsv text eol=lf

###############################################################################
# Config / project files
###############################################################################

*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

###############################################################################
# Windows scripts
###############################################################################

*.bat text eol=crlf
*.ps1 text eol=crlf

###############################################################################
# Binary files (never modify)
###############################################################################

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary

*.zip binary
*.gz binary
*.tar binary

*.pt binary
*.pth binary
*.ckpt binary
*.onnx binary

###############################################################################
# Notebooks
###############################################################################

*.ipynb text eol=lf